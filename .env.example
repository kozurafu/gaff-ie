# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://gaff:PASSWORD@localhost:5432/gaff

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-secret-key-here                        # min 32 chars, random

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://gaff.ie                    # required — used in email links

# ── Email (AgentMail) ─────────────────────────────────────────────────────────
AGENTMAIL_API_KEY=your-agentmail-key

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Image Storage (AWS S3 or Cloudflare R2) ───────────────────────────────────
AWS_REGION=eu-west-1
AWS_S3_BUCKET=gaff-uploads
# Optional: CDN / R2 public URL prefix (overrides default S3 URL)
AWS_S3_PUBLIC_URL=https://assets.gaff.ie
